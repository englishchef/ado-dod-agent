APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-with-secret-for-local-dev-only
AZURE_CREDENTIAL_MODE=default
AZURE_USER_ASSIGNED_CLIENT_ID=

# Phase 5A LLM smoke validation uses Microsoft Entra ID/RBAC only.
# No Azure OpenAI API key is used or supported. Activate PIM/RBAC before running it.
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=<api-version-from-portal>
AZURE_OPENAI_AUTH_MODE=entra
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=60

ADO_ORGANIZATION=your-ado-org
ADO_PROJECT=your-ado-project
ADO_API_VERSION=7.1

DATA_DIR=data
DOD_STORAGE_BACKEND=local_json
DOD_GRAPH_NAME=dod
DOD_ASSISTANT_NAME=dod
# Application-level safeguards for compact LangGraph checkpoint state.
DOD_GRAPH_STATE_WARN_BYTES=262144
DOD_GRAPH_STATE_MAX_BYTES=1048576

# Enterprise config pointer. When both are set, the app loads a JSON config
# secret from Key Vault with DefaultAzureCredential. Process env vars override it.
AGENT_CONFIG_KEY_VAULT_URL=
AGENT_CONFIG_SECRET_NAME=

# LangSmith observability. Disabled by default; failures must not fail DoD runs.
LANGSMITH_TRACING=false
# Backward-compatible alias used by some pipeline templates. LANGSMITH_TRACING wins.
TRACING_ENABLED=
LANGSMITH_PROJECT=dod-agent-local
LANGSMITH_ENDPOINT=
LANGSMITH_TLS_VERIFY=
LANGSMITH_CA_BUNDLE=
DOD_TRACE_MODE=summary

# LangGraph platform variables injected for callers/wrappers. The graph import
# does not require these values; assistant id defaults to dod.
LANGGRAPH_API_URL=
LANGGRAPH_ASSISTANT_ID=dod
LANGGRAPH_API_KEY_HEADER=
LANGGRAPH_KEY_VAULT_URL=
LANGGRAPH_KEY_VAULT_SECRET_NAME=

# Cosmos artifact storage. Use DOD_STORAGE_BACKEND=cosmos to enable.
# Local emulator:
# COSMOS_AUTH_MODE=emulator_key
# COSMOS_ENDPOINT=https://localhost:8081
# COSMOS_DATABASE=dod_agent_local
# COSMOS_CONTAINER=dod_runs
# COSMOS_KEY=<local-emulator-key-only>
#
# Enterprise:
# COSMOS_AUTH_MODE=default_credential
# COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/
# COSMOS_DATABASE=<database>
# COSMOS_CONTAINER=<container>
