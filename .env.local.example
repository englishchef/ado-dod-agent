APP_ENV=local
DOD_STORAGE_BACKEND=cosmos_local
DOD_COSMOS_EMULATOR_ENABLED=true

COSMOS_LOCAL_ENDPOINT=https://localhost:8081
COSMOS_LOCAL_DATABASE=dod_agent_local
COSMOS_LOCAL_CONTAINER=dod_runs
COSMOS_LOCAL_AUTH_MODE=emulator_key
COSMOS_LOCAL_KEY=<local-emulator-key-only>
COSMOS_LOCAL_DISABLE_TLS_VERIFY=false

DOD_GRAPH_NAME=dod
DOD_ASSISTANT_NAME=dod

LANGSMITH_TRACING=false
DOD_TRACE_MODE=summary

ADO_ORGANIZATION=
ADO_PROJECT=
